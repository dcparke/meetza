{
  "manifest_version": 3,
  "name": "Meetza",
  "version": "1.0.2",
  "description": "A small browser extension for sharing availability fast.",
  "permissions": ["identity", "storage", "scripting"],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "https://oauth2.googleapis.com/*"
  ],
  "optional_host_permissions": ["https://mail.google.com/*"],
  "background": {
    "scripts": ["platform.js", "common.js", "build-config.js", "auth.js", "background.js"]
  },
  "action": {
    "default_title": "Meetza Extension Settings",
    "default_popup": "popup.html",
    "default_icon": { "16": "icons/browser16.png", "32": "icons/browser32.png" }
  },
  "icons": {
    "16": "icons/browser16.png",
    "32": "icons/browser32.png",
    "48": "icons/browser48.png",
    "128": "icons/browser128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["content.css", "icons/icon32.png"],
      "matches": ["https://mail.google.com/*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'none'; script-src 'self'; style-src 'self'; img-src 'self'; connect-src https://www.googleapis.com https://oauth2.googleapis.com; object-src 'none'; base-uri 'none'; form-action 'none'; frame-ancestors 'none';"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "meetza@project.local",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["authenticationInfo", "personallyIdentifyingInfo"]
      }
    }
  }
}
